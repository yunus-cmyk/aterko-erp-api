# =============================================================================
# Aterko ERP — Ortam Değişkenleri Şablonu
# =============================================================================
# Bu dosyayı `.env` olarak kopyala ve gerçek değerleri doldur.
# .env dosyası GİT'E ASLA gönderilmez (.gitignore içinde).
#
#   cp .env.example .env
# =============================================================================

# Supabase PostgreSQL bağlantı string'i (Connection pooling URL kullan!)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase REST API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# JWT token imzalama anahtarı (rastgele 64+ karakterlik bir string üret)
JWT_SECRET=super-uzun-rastgele-bir-anahtar-buraya

# Google OAuth (frontend login için)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Gmail SMTP (bildirim/sipariş e-postaları)
GMAIL_USER=satinalma@aterko.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
